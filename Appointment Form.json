    "css": "/* setting the image as the background of the form */\r\n.fd-form {\r\n    background: linear-gradient(to right, #0000004d, #0000004d), url(\"https://plumsail.com/assets/forms/templates/appointment-form-image-01.jpg\") no-repeat center top;\r\n    -webkit-background-size: cover;\r\n    -moz-background-size: cover;\r\n    -o-background-size: cover;\r\n    background-size: cover;\r\n}\r\n\r\n/* setting a transparent background for the Heading control */\r\n.fd-form h1 > span,\r\n.fd-form h4 > span,\r\n.fd-form .fd-heading{\r\n   background-color: transparent !important;;\r\n}\r\n\r\n/* setting the background of Grid container */\r\n.fd-form .fd-blur-background {\r\n    background: rgb(223 223 223 / 18%);\r\n    backdrop-filter: blur(8px);\r\n    border-radius: 2px;\r\n}\r\n\r\n/* setting the text color to white */\r\n.fd-form .fd-heading__subheading,\r\n.fd-form h1,\r\n.fd-form h4,\r\n.fd-form .fd-field-title{\r\n    color: #ffff !important;\r\n}\r\n\r\n",
