    "css": "/* setting the image as the background of the form */\r\n.fd-form {\r\n    background: url(https://plumsail.com/assets/forms/templates/table-reservation-form-image-01.jpg) no-repeat center top ;\r\n    background-size: cover;\r\n}\r\n\r\n\r\n/* setting a transparent background for the Heading control */\r\n.fd-form h1 > span,\r\n.fd-form h4 > span,\r\n.fd-form .fd-heading{\r\n   background-color: transparent !important;;\r\n}\r\n\r\n/* setting the background of Grid container */\r\n.fd-form .fd-blur-background {\r\n    background: rgba(0, 0, 0, 0.2);\r\n    backdrop-filter: blur(8px);\r\n}\r\n\r\n/* setting the text color to white */\r\n.fd-form h4, .fd-form .h4,\r\n.fd-form .fd-field-title,\r\n.fd-form h1, .fd-form .h1{\r\n    color: white !important;\r\n}\r\n\r\n/* adding line to h4 */\r\n.fd-form h4:before, .fd-form h4:after, .fd-form h1:before, .fd-form h1:after{\r\n    content: \"\";\r\n    flex: 1 1;\r\n    border-bottom: 1px solid;\r\n    margin: auto;\r\n}\r\n\r\n.fd-form h4:before, .fd-form h1:before {\r\n    margin-right: 10px\r\n}\r\n\r\n.fd-form h4:after, .fd-form h1:after {\r\n    margin-left: 10px\r\n}",
