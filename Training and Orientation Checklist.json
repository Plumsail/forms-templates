    "js": "fd.rendered(function () {\r\n    const readOnlyColumns = ['Training', 'Responsible'];\r\n\r\n    // Initialize the 'General' table\r\n    initializeDataTable('General', general, readOnlyColumns);\r\n\r\n    // Initialize the 'Role' table\r\n    initializeDataTable('Role', roleSpecific, readOnlyColumns);\r\n});\r\n\r\nfunction initializeDataTable(controlName, defaultData, readOnlyFields) {\r\n    const dt = fd.control(controlName);\r\n\r\n    // Set default data if the table is empty\r\n    if (dt.value.length < 1) {\r\n        dt.value = defaultData;\r\n    }\r\n    // Hide add and delete column\r\n    $(dt.$el).find('.k-toolbar').hide();\r\n    $(dt.$el).find('.fd-datatable table tr th:last-child,.fd-datatable table tr td:last-child').hide();\r\n    // Configure specified columns to be read-only\r\n    readOnlyFields.forEach(fieldName => {\r\n        const column = dt.columns.find(c => c.field === fieldName);\r\n        // Make column read-only\r\n        column.editable = () => false;\r\n    });\r\n}\r\n\r\nlet general = [\r\n    { \"Training\": \"Welcome & Company History/Mission Review\", \"Responsible\": \"HR\" },\r\n    { \"Training\": \"Review of Employee Handbook (Includes general policies)\", \"Responsible\": \"HR\" },\r\n    { \"Training\": \"Workplace Health & Safety Training\", \"Responsible\": \"HR/Trainer\" },\r\n    { \"Training\": \"Code of Conduct & Ethics Training\", \"Responsible\": \"HR\" },\r\n    { \"Training\": \"Sexual Harassment & Anti-Discrimination Policy Review\", \"Responsible\": \"HR\" },\r\n    { \"Training\": \"IT Security & Data Privacy Policy Review\", \"Responsible\": \"IT/HR\" }\r\n];\r\n \r\nlet roleSpecific = [\r\n    { \"Training\": \"Introduction to Team/Team Structure\", \"Responsible\": \"Manager\" },\r\n    { \"Training\": \"Role and Key Performance Indicators (KPIs) Review\", \"Responsible\": \"Manager\" },\r\n    { \"Training\": \"Overview of Current Projects/Priorities\", \"Responsible\": \"Manager\" },\r\n    { \"Training\": \"Primary Role-Specific Software/Tool Training\", \"Responsible\": \"Manager/Peer\" },\r\n    { \"Training\": \"Process for Requesting Support/Escalation\", \"Responsible\": \"Manager\" },\r\n    { \"Training\": \"Introduction to Key Cross-Functional Contacts\", \"Responsible\": \"Manager\" }\r\n];",
